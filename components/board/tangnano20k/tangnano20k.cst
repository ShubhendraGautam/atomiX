// Sipeed Tang Nano 20K physical pin constraints (Gowin GW2AR-18C).
// Pins per the Sipeed schematic / LiteX platform: 27 MHz clock on 4,
// BL616 USB-serial on 69/70, user LEDs (active-low) on 15-20.

IO_LOC "clk_27mhz" 4;
IO_PORT "clk_27mhz" IO_TYPE=LVCMOS33;

IO_LOC "uart_tx" 69;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33 DRIVE=8;
IO_LOC "uart_rx" 70;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33 PULL_MODE=UP;

IO_LOC "led_n[0]" 15;
IO_LOC "led_n[1]" 16;
IO_LOC "led_n[2]" 17;
IO_LOC "led_n[3]" 18;
IO_LOC "led_n[4]" 19;
IO_LOC "led_n[5]" 20;
IO_PORT "led_n[0]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led_n[1]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led_n[2]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led_n[3]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led_n[4]" IO_TYPE=LVCMOS33 DRIVE=8;
IO_PORT "led_n[5]" IO_TYPE=LVCMOS33 DRIVE=8;
