# build outputs
*.o
*.a
*.elf
*.bin
*.hex
*.map
obj_dir*/
build/
# isolated FPGA synth trees from `make -C rtl/fpga ... BUILD=build-<tag>`
build-*/

# aXsim binary
sim/axsim/axsim

# simulation artifacts
*.vcd
*.fst
*.fst.hier
trace.log
__pycache__/

# FPGA flow outputs
*.json
# Component manifests and supplied build profiles are source inputs, not
# generated FPGA JSON. Keep these exceptions adjacent to the broad rule so
# new profiles are visible to Git by default.
!components/**/component.json
!configs/*.json
*.asc
*.bit
*.svf

# editor noise
*.swp
.vscode/
# Formal-generated jobs, solver databases, and counterexample traces.
formal/build/
